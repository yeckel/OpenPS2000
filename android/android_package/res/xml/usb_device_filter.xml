<?xml version="1.0" encoding="utf-8"?>
<!-- USB device filter — auto-attach intent for EA Elektro-Automatik PS 2000 B series.
     VID 0x0AAD = EA Elektro-Automatik. PIDs cover the common B-series models.
     The app also does a VID-only scan at runtime for unknown PIDs. -->
<resources>
    <!-- EA-PS 2000 B series: VID 0x232E = 9006, PID 0x0010 = 16 -->
    <usb-device vendor-id="9006" product-id="16" />
    <!-- vendor-id is decimal: 0x232E = 9006, product-id: 0x0010 = 16 -->
</resources>
